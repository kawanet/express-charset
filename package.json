{
  "name": "express-charset",
  "description": "Content-Type: text/xxxx; charset=xxxx",
  "version": "1.1.1",
  "author": "@kawanet",
  "bugs": {
    "url": "https://github.com/kawanet/express-charset/issues"
  },
  "dependencies": {
    "express-intercept": "^1.2.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.2",
    "@rollup/plugin-sucrase": "^5.0.2",
    "@types/express": "^5",
    "@types/express4": "npm:@types/express@^4",
    "@types/express5": "npm:@types/express@^5",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.2",
    "express4": "npm:express@^4",
    "express5": "npm:express@^5",
    "rollup": "^4.52.4",
    "supertest": "^7.0.0",
    "typescript": "^5.9.3"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "require": "./dist/express-charset.cjs",
      "import": {
        "types": "./types/express-charset.d.ts",
        "default": "./dist/express-charset.mjs"
      }
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/express-charset.cjs",
    "dist/express-charset.mjs",
    "lib/*.ts",
    "types/*.d.ts"
  ],
  "homepage": "https://github.com/kawanet/express-charset#readme",
  "keywords": [
    "charset",
    "content-type",
    "css",
    "expressjs",
    "html",
    "middleware",
    "xml"
  ],
  "license": "MIT",
  "main": "./dist/express-charset.cjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kawanet/express-charset.git"
  },
  "scripts": {
    "build": "make -C builder",
    "prepack": "if node -v | grep -q '^v20'; then echo 'ERROR: packing is not allowed on Node 20'; exit 1; fi",
    "prepare": "if node -v | grep -q '^v20'; then :; else make -C builder clean all test; fi",
    "test": "make -C builder test"
  },
  "sideEffects": false,
  "type": "module",
  "types": "types/express-charset.d.ts"
}
